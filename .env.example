# =====================================================================
# Ticket Bot — env шаблон.
# Скопируйте в .env и заполните секреты. См. docs/SPEC.md §13.
# =====================================================================

# -------- Telegram --------
BOT_TOKEN=
BOT_USE_WEBHOOK=false
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=

# -------- Командная группа (заполняется после /setup_team_group, см. SPEC §3.6) --------
EXECUTOR_GROUP_CHAT_ID=
EXECUTOR_GROUP_TOPIC_INCOMING=
EXECUTOR_GROUP_TOPIC_DIGEST=
EXECUTOR_GROUP_TOPIC_LOGS=

# -------- Иконки топиков (см. SPEC §6, §18.1) --------
# Получить список: getForumTopicIconStickers. Выбрать три и записать custom_emoji_id.
TOPIC_ICON_NEW=
TOPIC_ICON_IN_PROGRESS=
TOPIC_ICON_CLOSED=

# -------- Postgres --------
POSTGRES_DSN=postgresql+asyncpg://tickets:tickets@postgres:5432/tickets

# -------- Redis --------
# db=0 для стримов FastStream, db=1 для FSM, db=2 для кэша. Номер добавляется в коде.
REDIS_URL=redis://redis:6379

# -------- Конфиги --------
EXECUTORS_CONFIG_PATH=/app/config/executors.yaml

# -------- Google Sheets --------
GOOGLE_SHEETS_ID=
# Полный JSON service-account-ключа одной строкой
GOOGLE_SHEETS_CREDENTIALS_JSON=

# -------- Логи / Sentry --------
LOG_LEVEL=INFO
# json для prod, console для dev
LOG_FORMAT=console
SENTRY_DSN=

# -------- Scheduler --------
# Cron-выражение для ежедневной сводки в командную группу
DIGEST_CRON=0 9 * * *
TZ=Europe/Moscow
